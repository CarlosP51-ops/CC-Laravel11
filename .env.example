APP_NAME=CS-Store
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_TIMEZONE=UTC
APP_URL=https://your-app.onrender.com

APP_LOCALE=fr
APP_FALLBACK_LOCALE=fr

LOG_CHANNEL=stderr
LOG_LEVEL=error

# ── Base de données MySQL ─────────────────────────────────────────────────────
DB_CONNECTION=mysql
DB_HOST=your-mysql-host
DB_PORT=3306
DB_DATABASE=your_database
DB_USERNAME=your_username
DB_PASSWORD=your_password

# ── Sessions / Cache / Queue ──────────────────────────────────────────────────
SESSION_DRIVER=file
SESSION_LIFETIME=120
CACHE_STORE=file
QUEUE_CONNECTION=sync

# ── Fichiers ──────────────────────────────────────────────────────────────────
FILESYSTEM_DISK=public

# ── Broadcast (désactivé) ─────────────────────────────────────────────────────
BROADCAST_CONNECTION=null

# ── Mail ──────────────────────────────────────────────────────────────────────
MAIL_MAILER=smtp
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="noreply@cs-store.com"
MAIL_FROM_NAME="${APP_NAME}"

# ── Supabase Storage (images) ─────────────────────────────────────────────────
SUPABASE_URL=https://mllyppehfmdtiuiwwjku.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6Im1sbHlwcGVoZm1kdGl1aXd3amt1Iiwicm9sZSI6ImFub24iLCJpYXQiOjE3Nzc5OTUxNzcsImV4cCI6MjA5MzU3MTE3N30.4NDvqpCf8IXjLyR6bZUFAE2l23_rW2CzrUigOYkz1nw
SUPABASE_BUCKET=media
SUPABASE_PRIVATE_BUCKET=private-files

# ── Frontend URL (CORS) ───────────────────────────────────────────────────────
FRONTEND_URL=https://your-frontend.vercel.app
